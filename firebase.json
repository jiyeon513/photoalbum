{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "package.json",
      "package-lock.json",
      "firebase-config.example.js"
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|css|js|json|html|wasm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
